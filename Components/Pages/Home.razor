@page "/"

<PageTitle>Главная — ToyWorld</PageTitle>

<div class="tw-balloon-hero p-5 mb-5 text-center">
    <div class="tw-bubble" style="top: 20px; left: 30px;">🎈</div>
    <div class="tw-bubble" style="top: 60px; right: 50px; animation-delay: -1s;">🎁</div>
    <div class="tw-bubble" style="bottom: 30px; left: 80px; animation-delay: -2s;">🧸</div>
    <h1 class="display-2 fw-bold text-white">ToyWorld</h1>
    <p class="fs-3 text-warning fw-bold">— мир радости для детей и взрослых!</p>
    <a class="btn btn-light btn-lg fw-bold tw-cta" href="/products"><i class="bi bi-rocket-takeoff"></i> Поехали выбирать!</a>
</div>

<div class="row g-4">
    <div class="col-md-6 col-lg-3"><div class="tw-tile p-4 text-center" style="transform: rotate(-2deg);"><i class="bi bi-puzzle text-tw" style="font-size: 3rem;"></i><h5 class="mt-2">Конструкторы</h5><small class="text-muted">LEGO и магнитные</small></div></div>
    <div class="col-md-6 col-lg-3"><div class="tw-tile p-4 text-center" style="transform: rotate(1.5deg);"><i class="bi bi-emoji-laughing text-tw" style="font-size: 3rem;"></i><h5 class="mt-2">Куклы</h5><small class="text-muted">Barbie и L.O.L.</small></div></div>
    <div class="col-md-6 col-lg-3"><div class="tw-tile p-4 text-center" style="transform: rotate(-1deg);"><i class="bi bi-car-front-fill text-tw" style="font-size: 3rem;"></i><h5 class="mt-2">Машинки</h5><small class="text-muted">р/у и Hot Wheels</small></div></div>
    <div class="col-md-6 col-lg-3"><div class="tw-tile p-4 text-center" style="transform: rotate(2deg);"><i class="bi bi-gift text-tw" style="font-size: 3rem;"></i><h5 class="mt-2">Подарки</h5><small class="text-muted">Упаковка в подарок</small></div></div>
</div>